{
  "name": "water-supply-dispatch",
  "version": "1.0.0",
  "description": "供水调度后端服务 - 面向调度大屏、值班App和客服系统提供统一能力",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/app.js",
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "seed": "ts-node src/database/seed.ts",
    "lint": "eslint src/**/*.ts --fix"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "helmet": "^8.0.0",
    "joi": "^17.13.3",
    "winston": "^3.15.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.7.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2"
  }
}
